# =============================================================================
# Ingest — biến môi trường gom từ các playground
#
# | Biến                  | Playground nguồn              | Lệnh ingest        |
# |-----------------------|-------------------------------|--------------------|
# | MONGODB_*             | ingest                        | mọi lệnh ghi DB    |
# | RAPIDAPI_KEY          | playground/X-API              | twitter, all       |
# | ALPHA_VANTAGE_API_KEY | playground/alpha_vantage      | news-av, all       |
# | REDDIT_USER_AGENT     | ingest (Reddit API policy)    | reddit, all        |
# | (không cần key)       | playground/yahoo_finance      | news-yahoo         |
# | (không cần key)       | playground/finetune/fasttext  | —                  |
# | OPENROUTER_*          | playground/ner (Stage 3)      | NER LLM modes      |
# =============================================================================

# --- MongoDB Atlas (ingest Stage 1) ---
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB=crypto_mvp
MONGODB_COLLECTION=raw_events

# --- playground/X-API + ingest twitter ---
RAPIDAPI_KEY=your-rapidapi-key

# --- playground/alpha_vantage + ingest news-av ---
ALPHA_VANTAGE_API_KEY=your-alphavantage-key

# --- ingest reddit (OAuth — bắt buộc từ ~2023, public JSON thường 403) ---
# Tạo app: https://www.reddit.com/prefs/apps → "create another app" → type script
REDDIT_CLIENT_ID=your-client-id-under-app-name
REDDIT_CLIENT_SECRET=your-client-secret
REDDIT_USERNAME=your_reddit_username
REDDIT_PASSWORD=your_reddit_password_or_app_password
# Format Reddit yêu cầu: platform:app_id:version (by /u/username)
REDDIT_USER_AGENT=linux:crypto-ingest-playground:v0.1 (by /u/your_reddit_username)

# --- Reddit browser (Playwright, lệnh: reddit --browser) ---
# REDDIT_BROWSER_HEADLESS=false
# REDDIT_BROWSER_STORAGE=./.reddit_session.json

# --- playground/ner (Stage 3 — OpenRouter LLM) ---
# OPENROUTER_API_KEY=sk-or-v1-...
# OPENROUTER_MODEL=google/gemini-2.0-flash-001
# NER_MODE=hybrid
