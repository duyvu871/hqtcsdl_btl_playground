# Stage 4 Sentiment — override tuỳ chọn; MongoDB đọc từ playground/ingest/.env

# --- MongoDB ---
# MONGODB_URI=mongodb://localhost:27017
# MONGODB_DB=crypto_mvp
# MONGODB_MAPPED_COLLECTION=mapped_events
# MONGODB_CLEAN_COLLECTION=clean_events
# MONGODB_SENTIMENT_COLLECTION=sentiment_events
# MONGODB_AGGREGATE_COLLECTION=sentiment_aggregates

# --- Sentiment Model ---
# Mặc định: ProsusAI/finbert
# Thay bằng ElKulako/cryptobert cho crypto-specific
# Hoặc wonrax/phobert-base-vietnamese-sentiment cho tiếng Việt
SENTIMENT_MODEL=ProsusAI/finbert
SENTIMENT_BATCH_SIZE=100
SENTIMENT_MAX_LENGTH=256
SENTIMENT_USE_RULE_FALLBACK=true
