# Filter — Stage 2 (override tuỳ chọn; MongoDB đọc từ playground/ingest/.env)

# --- Stage 3 NER (OpenRouter) ---
# OPENROUTER_API_KEY=sk-or-v1-...
# OPENROUTER_MODEL=google/gemini-2.0-flash-001
# NER_MODE=hybrid

# Collection output Stage 2
# MONGODB_CLEAN_COLLECTION=clean_events
# MONGODB_DROPPED_COLLECTION=dropped_events

# FastText model (train tại playground/finetune/fasttext)
# FASTTEXT_MODEL_PATH=../finetune/fasttext/models/spam_model.bin
