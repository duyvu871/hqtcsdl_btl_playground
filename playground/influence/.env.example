# Stage 5 Influence Weighting
# Module này chỉ đọc output của Stage 4 và ghi output cho Stage 6.
# Không dùng Kafka/Redis trong bản này để đồng bộ với các stage playground hiện tại.

# --- MongoDB ---
# Mặc định module sẽ load playground/ingest/.env trước, rồi load playground/influence/.env sau.
# Nếu đã có MONGODB_URI trong playground/ingest/.env thì không cần khai báo lại ở đây.
# MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=crypto_mvp

# Input từ Stage 4
MONGODB_SENTIMENT_COLLECTION=sentiment_events

# Output của Stage 5
MONGODB_WEIGHTED_COLLECTION=weighted_events
MONGODB_INFLUENCE_AGG_COLLECTION=influence_aggregates

# --- Influence formula ---
MAX_INFLUENCE=20
CORE_SCALE=8.0
ALPHA_AUTHOR=0.35
BETA_ENGAGEMENT=0.40
GAMMA_VIRALITY=0.25
DELTA_NETWORK=0.0

# Half-life theo source, đơn vị giờ
TWITTER_HALF_LIFE_HOURS=12
REDDIT_HALF_LIFE_HOURS=24
NEWS_HALF_LIFE_HOURS=36
DEFAULT_HALF_LIFE_HOURS=24

# Nếu event không có expected_author_engagement thì dùng baseline này
DEFAULT_EXPECTED_ENGAGEMENT=50
