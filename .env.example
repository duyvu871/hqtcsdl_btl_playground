# --- Infrastructure (required) ---
# Host ports 6378/27018 tránh xung đột với redis/mongo khác trên máy (6380, 27017).
REDIS_URL=redis://localhost:6378/0
MONGODB_URI=mongodb://localhost:27018
MONGODB_DB=crypto_mvp

# --- External APIs (optional per stage) ---
RAPIDAPI_KEY=
ALPHA_VANTAGE_API_KEY=
OPENROUTER_API_KEY=
OPENROUTER_INSIGHT_MODEL=anthropic/claude-3.5-sonnet

# Reddit OAuth (optional — ingest reddit)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USERNAME=
REDDIT_PASSWORD=
REDDIT_USER_AGENT=linux:crypto-social-intelligence:v0.1 (by /u/username)

# --- Pipeline tuning ---
FASTTEXT_MODEL_PATH=models/spam/spam_model.bin
STREAM_MAXLEN=50000
STREAM_CLAIM_IDLE_MS=30000
STREAM_MAX_RETRY=3
SESSION_TTL_DAYS=7
